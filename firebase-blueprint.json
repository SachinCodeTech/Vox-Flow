{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Enterprise user profile for VoxOS.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "The full name of the user." },
        "email": { "type": "string", "description": "The email address of the user." },
        "role": { "type": "string", "description": "Enterprise role (e.g., Administrator, Architect)." },
        "deptId": { "type": "string", "description": "Department association." },
        "avatarUrl": { "type": "string", "description": "Profile picture URL." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Workspace": {
      "title": "Neural Workspace",
      "description": "A container for neural logic nodes and edges.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "nodes": { "type": "array" },
        "edges": { "type": "array" }
      },
      "required": ["id", "name", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles."
    },
    "/workspaces/{workspaceId}": {
      "schema": "Workspace",
      "description": "Top-level workspaces owned by users."
    }
  }
}
